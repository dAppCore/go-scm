go 1.26.2

// Workspace mode for development: pulls fresh code from external/ submodules.
// CI uses GOWORK=off to fall back to go/go.mod tags (reproducible).

use (
	./go
	./external/go
	./external/cli/go
	./external/config/go
	./external/io/go
	./external/process/go
	./external/ws/go
	./external/log/go
)
